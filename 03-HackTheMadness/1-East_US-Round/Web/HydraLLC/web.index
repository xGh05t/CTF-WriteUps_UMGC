<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meet the Team</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="icon" href="/static/images/favicon.png" type="image/png">
    <style>
        .team-member { margin-bottom: 20px; }
        .navbar-brand img { 
            height: 30px;
            margin-right: 10px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">
                <img src="/static/images/favicon.png" alt="Logo">
                Hydra LLC
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/">Meet the Team</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <h2>Meet the Team</h2>
        <div class="row">
            <div class="col-md-4 team-member">
                <img src="/static/images/alex-johnson.webp" class="img-fluid rounded-circle" alt="Alex Johnson">
                <h3>Alex Johnson</h3>
                <p>CEO</p>
                <a href="mailto:alex.johnson@hydra.llc" data-bs-toggle="tooltip" data-bs-placement="top" title="Email Alex Johnson">alex.johnson@hydra.llc</a>
            </div>
            <div class="col-md-4 team-member">
                <img src="/static/images/morgan-smith.webp" class="img-fluid rounded-circle" alt="Morgan Smith">
                <h3>Morgan Smith</h3>
                <p>CTO</p>
                <a href="mailto:morgan.smith@hydra.llc" data-bs-toggle="tooltip" data-bs-placement="top" title="Email Morgan Smith">morgan.smith@hydra.llc</a>
            </div>
            <div class="col-md-4 team-member">
                <img src="/static/images/taylor-lee.webp" class="img-fluid rounded-circle" alt="Taylor Lee">
                <h3>Taylor Lee</h3>
                <p>Product Manager</p>
                <a href="mailto:taylor.lee@hydra.llc" data-bs-toggle="tooltip" data-bs-placement="top" title="Email Taylor Lee">taylor.lee@hydra.llc</a>
            </div>
            <div class="col-md-4 team-member">
                <img src="/static/images/jordan-kim.webp" class="img-fluid rounded-circle" alt="Jordan Kim">
                <h3>Jordan Kim</h3>
                <p>UX Strategist</p>
                <a href="mailto:jordan.kim@hydra.llc" data-bs-toggle="tooltip" data-bs-placement="top" title="Email Jordan Kim">jordan.kim@hydra.llc</a>
            </div>
            <div class="col-md-4 team-member">
                <img src="/static/images/casey-rivera.webp" class="img-fluid rounded-circle" alt="Casey Rivera">
                <h3>Casey Rivera</h3>
                <p>Lead Developer</p>
                <a href="mailto:casey.rivera@hydra.llc" data-bs-toggle="tooltip" data-bs-placement="top" title="Email Casey Rivera">casey.rivera@hydra.llc</a>
            </div>
            <div class="col-md-4 team-member">
                <img src="/static/images/jamie-parker.webp" class="img-fluid rounded-circle" alt="Jamie Parker">
                <h3>Jamie Parker</h3>
                <p>Marketing Lead</p>
                <a href="mailto:jamie.parker@hydra.llc" data-bs-toggle="tooltip" data-bs-placement="top" title="Email Jamie Parker">jamie.parker@hydra.llc</a>
            </div>
        </div>
    </div>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>    <!-- Initialize tooltips -->
    <script>
      var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
      var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl)
      })
    </script>
</body>
</html>